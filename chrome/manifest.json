{
  "manifest_version": 3,
  "name": "Nexus Agent",
  "version": "0.1.0",
  "description": "Lets Nexus-AI agents operate your browser on your behalf.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Nexus Agent",
    "default_icon": {
      "16": "icons/icon-offline-16.png",
      "48": "icons/icon-offline-48.png",
      "128": "icons/icon-offline-128.png"
    }
  },
  "options_page": "options/options.html",
  "commands": {
    "pause-all-agents": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Pause all running Nexus agents"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
